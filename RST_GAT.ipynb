      "source": [
        "from sklearn.metrics import r2_score\n",
        "import numpy as np\n",
        "\n",
        "def print_accuracy_metrics(y_true, y_pred):\n",
        "    print(\"\\n\" + \"═\" * 70)\n",
        "    print(\"PERCENTAGE-BASED ACCURACY METRICS\".center(70))\n",
        "    print(\"═\" * 70)\n",
        "\n",
        "    # 1. R-squared Score\n",
        "    r2 = r2_score(y_true, y_pred)\n",
        "\n",
        "    # 2. Threshold Accuracies (rounding predictions to nearest integer)\n",
        "    preds_rounded = np.round(y_pred)\n",
        "    y_true_rounded = np.round(y_true)\n",
        "\n",
        "    # Calculate percentages\n",
        "    exact_matches = np.mean(preds_rounded == y_true_rounded) * 100\n",
        "    within_one = np.mean(np.abs(preds_rounded - y_true_rounded) <= 1) * 100\n",
        "\n",
        "    print(f\"R-squared Score:           {r2:.4f} (Explains {r2*100:.1f}% of the variance)\")\n",
        "    print(f\"Exact Match Accuracy:      {exact_matches:.2f}% (Predicted exact number of crimes)\")\n",
        "    print(f\"Accuracy within ±1 crime:  {within_one:.2f}% (Predicted within 1 crime margin)\")\n",
        "    print(\"═\" * 70)\n",
        "\n",
        "# Run the function using the real predictions generated in the previous cell\n",
        "print_accuracy_metrics(y_true_real, preds_real)"
      ],
