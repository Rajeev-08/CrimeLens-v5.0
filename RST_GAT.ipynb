        "def print_box(title, lines):\n",
        "    print(\"\\n\" + \"═\" * 70)\n",
        "    print(title.center(70))\n",
        "    print(\"═\" * 70)\n",
        "    for line in lines:\n",
        "        print(line)\n",
        "    print(\"═\" * 70)\n",
        "\n",
        "# ---------------------------------------------------\n",
        "# SETUP DIRECTORIES\n",
        "# ---------------------------------------------------\n",
        "os.makedirs(\"saved_models\", exist_ok=True)\n",
        "os.makedirs(\"reports\", exist_ok=True)\n",
        "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "\n",
        "# ---------------------------------------------------\n",
        "# LOAD DATA\n",
        "# ---------------------------------------------------\n",
        "print(f\"Using Device: {device}\")\n",
        "print(\"Loading dataset...\")\n",
        "df = load_crime_data(\"crime_data.csv\") # Changed path for Colab root\n",
        "\n",
        "print(\"Creating grid...\")\n",
        "df = create_grid(df)\n",
        "grids = get_unique_grids(df)\n",
        "\n",
        "with open(\"saved_models/grids.pkl\", \"wb\") as f:\n",
        "    pickle.dump(grids, f)\n",
        "\n",
        "print(\"Creating features...\")\n",
        "data, months = create_monthly_features(df, grids)\n",
        "print(\"Total months:\", len(months))\n",
        "\n",
        "print(\"Creating sliding windows...\")\n",
        "X, y = create_sliding_windows(data, window_size=6)\n",
        "T, W, N, F = X.shape\n",
        "split = int(0.8 * T)\n",
        "\n",
        "X_train_raw, X_test_raw = X[:split], X[split:]\n",
        "y_train, y_test = np.log1p(y[:split]), np.log1p(y[split:])\n",
        "\n",
        "# ---------------------------------------------------\n",
        "# NORMALIZATION\n",
        "# ---------------------------------------------------\n",
        "print(\"Normalizing features...\")\n",
        "scaler = StandardScaler()\n",
        "X_train_flat = X_train_raw.reshape(-1, F)\n",
        "X_train_scaled = scaler.fit_transform(X_train_flat)\n",
        "\n",
        "with open(\"saved_models/scaler.pkl\", \"wb\") as f:\n",
        "    pickle.dump(scaler, f)\n",
        "\n",
        "X_test_flat = X_test_raw.reshape(-1, F)\n",
        "X_test_scaled = scaler.transform(X_test_flat)\n",
        "\n",
        "X_train = X_train_scaled.reshape(X_train_raw.shape)\n",
        "X_test = X_test_scaled.reshape(X_test_raw.shape)\n",
        "\n",
        "# ---------------------------------------------------\n",
        "# BASELINES\n",
        "# ---------------------------------------------------\n",
        "print(\"Running Baselines...\")\n",
        "Xb_train, yb_train = prepare_baseline_data(X_train, y_train)\n",
        "Xb_test, yb_test = prepare_baseline_data(X_test, y_test)\n",
        "baseline_results = train_and_evaluate_baselines(Xb_train, yb_train, Xb_test, yb_test)\n",
        "\n",
        "# ---------------------------------------------------\n",
        "# GRAPH & SPATIAL METRICS\n",
        "# ---------------------------------------------------\n",
        "print(\"Building graph...\")\n",
        "edge_index = build_static_graph(grids)\n",
        "print(\"Computing Moran's I...\")\n",
        "adj_matrix = edge_index_to_adjacency(edge_index, len(grids))\n",
        "last_month_values = data[-1, :, 0]\n",
        "moran_value = morans_i(last_month_values, adj_matrix)\n",
        "\n",
        "# ---------------------------------------------------\n",
        "# ST-GAT TRAINING\n",
        "# ---------------------------------------------------\n",
        "print(\"Initializing and Training ST-GAT model...\")\n",
        "model = STGAT(window_size=6, feature_dim=F)\n",
        "model = train_model(model, X_train, y_train, X_test, y_test, edge_index, epochs=60)\n",
        "\n",
        "# ---------------------------------------------------\n",
        "# EVALUATION & ACCURACY\n",
        "# ---------------------------------------------------\n",
        "print(\"Evaluating ST-GAT...\")\n",
        "model.eval()\n",
        "preds = []\n",
        "\n",
        "for t in range(len(X_test)):\n",
        "    with torch.no_grad():\n",
        "        x_input = torch.tensor(X_test[t], dtype=torch.float).permute(1, 0, 2).to(device)\n",
        "        output = model(x_input, edge_index.to(device))\n",
        "        preds.append(output.cpu().numpy())\n",
        "\n",
        "preds = np.array(preds)\n",
        "y_true_real = np.expm1(y_test.flatten())\n",
        "preds_real = np.expm1(preds.flatten())\n",
        "\n",
        "stgat_results = evaluate(y_true_real, preds_real)\n",
        "f1 = high_risk_f1(y_true_real, preds_real)\n",
        "\n",
        "# ---------------------------------------------------\n",
        "# ABLATION\n",
        "# ---------------------------------------------------\n",
        "print(\"Running Ablation Study...\")\n",
        "ablation_results = {}\n",
        "ab_models = {\"MLP\": MLPOnly(6, F), \"GATOnly\": GATOnly(6, F)}\n",
        "\n",
        "for name, ab_model in ab_models.items():\n",
        "    ab_model = ab_model.to(device)\n",
        "    optimizer = torch.optim.Adam(ab_model.parameters(), lr=0.001, weight_decay=1e-4)\n",
        "    criterion = torch.nn.MSELoss()\n",
        "\n",
        "    for epoch in range(20):\n",
        "        for t in range(len(X_train)):\n",
        "            optimizer.zero_grad()\n",
        "            x_input = torch.tensor(X_train[t], dtype=torch.float).permute(1, 0, 2).to(device)\n",
        "            y_true_t = torch.tensor(y_train[t], dtype=torch.float).to(device)\n",
        "            output = ab_model(x_input, edge_index.to(device))\n",
        "            loss = criterion(output, y_true_t)\n",
        "            loss.backward()\n",
        "            optimizer.step()\n",
        "\n",
        "    preds_ab = []\n",
        "    for t in range(len(X_test)):\n",
        "        with torch.no_grad():\n",
        "            x_input = torch.tensor(X_test[t], dtype=torch.float).permute(1, 0, 2).to(device)\n",
        "            output = ab_model(x_input, edge_index.to(device))\n",
        "            preds_ab.append(output.cpu().numpy())\n",
        "\n",
        "    preds_ab = np.array(preds_ab)\n",
        "    preds_real_ab = np.expm1(preds_ab.flatten())\n",
        "    ablation_results[name] = evaluate(y_true_real, preds_real_ab)\n",
        "\n",
        "ablation_results[\"ST-GAT\"] = stgat_results\n",
        "\n",
        "# ---------------------------------------------------\n",
        "# PRINT RESULTS\n",
        "# ---------------------------------------------------\n",
        "print_box(\"BASELINE MODELS\", [f\"{k:<15} | MAE: {v['MAE']:.4f} | RMSE: {v['RMSE']:.4f}\" for k, v in baseline_results.items()])\n",
        "print_box(\"ST-GAT RESULTS\", [f\"MAE: {stgat_results['MAE']:.4f}\", f\"RMSE: {stgat_results['RMSE']:.4f}\", f\"High-Risk F1: {f1:.4f}\"])\n",
        "print_box(\"ABLATION STUDY\", [f\"{k:<15} | MAE: {v['MAE']:.4f} | RMSE: {v['RMSE']:.4f}\" for k, v in ablation_results.items()])\n",
        "print_box(\"SPATIAL AUTOCORRELATION\", [f\"Global Moran's I: {moran_value:.6f}\"])\n",
        "\n",
        "torch.save(model.state_dict(), \"saved_models/stgat_model.pth\")\n",
        "print(\"\\nModel saved to saved_models/stgat_model.pth\")\n",
        "\n",
        "# --- PLOT ACCURACY CHARTS ---\n",
        "print(\"\\n--- Visualizing Accuracy ---\")\n",
        "plot_predictions(y_true_real, preds_real)\n",
        "plot_error_distribution(y_true_real, preds_real)"
      ],
