      "cell_type": "code",
      "source": [
        "class STGAT(nn.Module):\n",
        "    def __init__(self, window_size, feature_dim):\n",
        "        super(STGAT, self).__init__()\n",
        "        self.window_size = window_size\n",
        "        self.gat1 = GATConv(feature_dim, 64, heads=4, concat=True)\n",
        "        self.gat2 = GATConv(64 * 4, 64, heads=1, concat=False)\n",
        "        self.dropout = nn.Dropout(0.2)\n",
        "        self.norm = nn.LayerNorm(64)\n",
        "        self.fc = nn.Linear(64, 1)\n",
        "\n",
        "    def forward(self, x, edge_index):\n",
        "        N, W, F = x.shape\n",
        "        spatial_embeddings = []\n",
        "\n",
        "        for t in range(W):\n",
        "            x_t = x[:, t, :]\n",
        "            h = torch.relu(self.gat1(x_t, edge_index))\n",
        "            h = torch.relu(self.gat2(h, edge_index))\n",
        "            h = self.dropout(h)\n",
        "            h = self.norm(h)\n",
        "            spatial_embeddings.append(h)\n",
        "\n",
        "        h_seq = torch.stack(spatial_embeddings, dim=1)\n",
        "        h_last = h_seq[:, -1, :]\n",
        "        h_mean = torch.mean(h_seq, dim=1)\n",
        "        h_combined = h_last + 0.3 * h_mean\n",
        "        out = self.fc(h_combined)\n",
        "        return out.squeeze()\n",
        "\n",
        "class MLPOnly(nn.Module):\n",
        "    def __init__(self, window_size, feature_dim):\n",
        "        super().__init__()\n",
        "        self.window_size = window_size\n",
        "        self.feature_dim = feature_dim\n",
        "        self.fc1 = nn.Linear(window_size * feature_dim, 128)\n",
        "        self.fc2 = nn.Linear(128, 1)\n",
        "\n",
        "    def forward(self, x, edge_index=None):\n",
        "        N, W, F = x.shape\n",
        "        x = x.reshape(N, W * F)\n",
        "        h = torch.relu(self.fc1(x))\n",
        "        out = self.fc2(h)\n",
        "        return out.squeeze()\n",
        "\n",
        "class GATOnly(nn.Module):\n",
        "    def __init__(self, window_size, feature_dim):\n",
        "        super().__init__()\n",
        "        self.gat1 = GATConv(feature_dim, 64, heads=4, concat=True)\n",
        "        self.gat2 = GATConv(64 * 4, 64, heads=1, concat=False)\n",
        "        self.fc = nn.Linear(64, 1)\n",
        "\n",
        "    def forward(self, x, edge_index):\n",
        "        x_last = x[:, -1, :]\n",
        "        h = torch.relu(self.gat1(x_last, edge_index))\n",
        "        h = torch.relu(self.gat2(h, edge_index))\n",
        "        out = self.fc(h)\n",
        "        return out.squeeze()\n",
        "\n",
        "def get_baseline_models():\n",
        "    return {\n",
        "        \"LinearRegression\": LinearRegression(),\n",
        "        \"RandomForest\": RandomForestRegressor(n_estimators=30, max_depth=10, n_jobs=-1, random_state=42),\n",
        "        \"XGBoost\": XGBRegressor(n_estimators=50, max_depth=6, learning_rate=0.1, n_jobs=-1, random_state=42, verbosity=0)\n",
        "    }"
      ],
