      "cell_type": "code",
      "source": [
        "def load_crime_data(path):\n",
        "    df = pd.read_csv(path)\n",
        "    print(\"Available Columns:\")\n",
        "    print(df.columns)\n",
        "    df['DATE OCC'] = pd.to_datetime(\n",
        "        df['DATE OCC'],\n",
        "        format='%m/%d/%Y %I:%M:%S %p',\n",
        "        errors='coerce',\n",
        "        exact=False\n",
        "    )\n",
        "    df = df.dropna(subset=['LAT', 'LON', 'DATE OCC'])\n",
        "    df = df[df['LAT'] != 0]\n",
        "    df = df[df['LON'] != 0]\n",
        "    print(\"Date range:\", df[\"DATE OCC\"].min(), df[\"DATE OCC\"].max())\n",
        "    return df\n",
        "\n",
        "def create_grid(df, cell_size=0.02):\n",
        "    df = df.dropna(subset=[\"LAT\", \"LON\"]).copy()\n",
        "    df[\"grid_x\"] = (df[\"LAT\"] / cell_size).astype(int)\n",
        "    df[\"grid_y\"] = (df[\"LON\"] / cell_size).astype(int)\n",
        "    df[\"grid_id\"] = df[\"grid_x\"].astype(str) + \"_\" + df[\"grid_y\"].astype(str)\n",
        "    return df\n",
        "\n",
        "def get_unique_grids(df):\n",
        "    return sorted(df[\"grid_id\"].unique())\n",
        "\n",
        "def build_static_graph(grids):\n",
        "    grid_coords = {}\n",
        "    for idx, grid in enumerate(grids):\n",
        "        x, y = map(int, grid.split(\"_\"))\n",
        "        grid_coords[idx] = (x, y)\n",
        "\n",
        "    edge_index = []\n",
        "    for i in grid_coords:\n",
        "        x1, y1 = grid_coords[i]\n",
        "        for j in grid_coords:\n",
        "            if i == j: continue\n",
        "            x2, y2 = grid_coords[j]\n",
        "            # 4-neighbour connectivity\n",
        "            if abs(x1 - x2) + abs(y1 - y2) == 1:\n",
        "                edge_index.append([i, j])\n",
        "\n",
        "    return torch.tensor(edge_index, dtype=torch.long).t().contiguous()\n",
        "\n",
        "def build_dynamic_edges(features_t, base_edge_index, similarity_threshold=0.92, max_dynamic_neighbors=3):\n",
        "    num_nodes = features_t.shape[0]\n",
        "    edge_set = set()\n",
        "    base_edges = base_edge_index.cpu().numpy().T\n",
        "    for i, j in base_edges:\n",
        "        edge_set.add((i, j))\n",
        "        edge_set.add((j, i))\n",
        "\n",
        "    sim_matrix = cosine_similarity(features_t)\n",
        "    for i in range(num_nodes):\n",
        "        sim_scores = sim_matrix[i]\n",
        "        sorted_idx = np.argsort(-sim_scores)\n",
        "        added = 0\n",
        "        for j in sorted_idx:\n",
        "            if i == j: continue\n",
        "            if sim_scores[j] > similarity_threshold:\n",
        "                edge_set.add((i, j))\n",
        "                edge_set.add((j, i))\n",
        "                added += 1\n",
        "                if added >= max_dynamic_neighbors: break\n",
        "\n",
        "    return torch.tensor(list(edge_set), dtype=torch.long).t().contiguous()\n",
        "\n",
        "def create_monthly_features(df, grids):\n",
        "    if \"grid_id\" not in df.columns:\n",
        "        raise ValueError(\"grid_id column not found. Make sure create_grid() adds df['grid_id']\")\n",
        "\n",
        "    df[\"DATE OCC\"] = pd.to_datetime(df[\"DATE OCC\"], errors=\"coerce\")\n",
        "    df[\"month\"] = df[\"DATE OCC\"].dt.to_period(\"M\").astype(str)\n",
        "\n",
        "    print(\"Encoding crime descriptions...\")\n",
        "    model = SentenceTransformer(\"sentence-transformers/all-MiniLM-L6-v2\")\n",
        "    unique_crimes = df[\"Crm Cd Desc\"].fillna(\"Unknown\").unique()\n",
        "    print(\"Unique crime types found:\", len(unique_crimes))\n",
        "\n",
        "    crime_to_embedding = {}\n",
        "    batch_size = 32\n",
        "    for i in tqdm(range(0, len(unique_crimes), batch_size)):\n",
        "        batch = unique_crimes[i:i + batch_size]\n",
        "        embeddings = model.encode(batch, convert_to_numpy=True)\n",
        "        for crime, emb in zip(batch, embeddings):\n",
        "            crime_to_embedding[crime] = emb\n",
        "\n",
        "    df[\"text_emb\"] = df[\"Crm Cd Desc\"].fillna(\"Unknown\").map(crime_to_embedding)\n",
        "\n",
        "    print(\"Applying PCA to text embeddings...\")\n",
        "    all_embeddings = np.vstack(df[\"text_emb\"].values)\n",
        "    pca = PCA(n_components=32)\n",
        "    reduced_embeddings = pca.fit_transform(all_embeddings)\n",
        "    df[\"text_emb_reduced\"] = list(reduced_embeddings)\n",
        "\n",
        "    grouped = df.groupby([\"month\", \"grid_id\"])\n",
        "    months = sorted(df[\"month\"].unique())\n",
        "    num_months = len(months)\n",
        "    num_grids = len(grids)\n",
        "\n",
        "    feature_dim = 1 + 32\n",
        "    data = np.zeros((num_months, num_grids, feature_dim))\n",
        "\n",
        "    month_to_index = {m: i for i, m in enumerate(months)}\n",
        "    grid_to_index = {g: i for i, g in enumerate(grids)}\n",
        "\n",
        "    print(\"Building monthly feature tensor...\")\n",
        "    for (month, grid), group in tqdm(grouped):\n",
        "        if grid not in grid_to_index: continue\n",
        "        t = month_to_index[month]\n",
        "        node = grid_to_index[grid]\n",
        "\n",
        "        crime_count = np.log1p(len(group))\n",
        "        mean_embedding = np.mean(np.vstack(group[\"text_emb_reduced\"].values), axis=0)\n",
        "\n",
        "        data[t, node, 0] = crime_count\n",
        "        data[t, node, 1:] = mean_embedding\n",
        "\n",
        "    return data, months\n",
        "\n",
        "def create_sliding_windows(data, window_size=6):\n",
        "    T, N, F = data.shape\n",
        "    X, y = [], []\n",
        "    for t in range(window_size, T):\n",
        "        X.append(data[t-window_size:t])\n",
        "        y.append(data[t, :, 0])  # predict crime_count only\n",
        "    return np.array(X), np.array(y)\n",
        "\n",
        "def prepare_baseline_data(X, y):\n",
        "    T, W, N, F = X.shape\n",
        "    X_last = X[:, -1, :, :]  # (T, N, F)\n",
        "    return X_last.reshape(T * N, F), y.reshape(T * N)\n",
        "\n",
        "def edge_index_to_adjacency(edge_index, num_nodes):\n",
        "    adj = np.zeros((num_nodes, num_nodes))\n",
        "    edges = edge_index.cpu().numpy().T\n",
        "    for i, j in edges:\n",
        "        adj[i, j] = 1\n",
        "        adj[j, i] = 1\n",
        "    return adj\n",
        "\n",
        "def morans_i(values, adjacency):\n",
        "    N = len(values)\n",
        "    mean = np.mean(values)\n",
        "    diff = values - mean\n",
        "    numerator = 0\n",
        "    for i in range(N):\n",
        "        for j in range(N):\n",
        "            numerator += adjacency[i, j] * diff[i] * diff[j]\n",
        "    denominator = np.sum(diff ** 2)\n",
        "    W = np.sum(adjacency)\n",
        "    return (N / W) * (numerator / denominator)"
      ],
      "metadata": {
